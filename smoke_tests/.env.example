# =============================================================
# qTest API Configuration - Copy this file to .env and fill in
# =============================================================

# Your qTest instance domain (e.g. "mycompany" for mycompany.qtestnet.com)
QTEST_DOMAIN=your-domain

# Full base URL (auto-constructed if QTEST_DOMAIN is set, or override here)
# QTEST_BASE_URL=https://your-domain.qtestnet.com

# Authentication — choose ONE method:
# Method 1: Pre-generated API token (recommended for scripts)
QTEST_BEARER_TOKEN=your-bearer-token-here

# Method 2: Username/password login (token fetched at runtime)
# QTEST_USERNAME=your-email@company.com
# QTEST_PASSWORD=your-password

# Project ID (numeric) — find this in qTest URL or via GET /api/v3/projects
QTEST_PROJECT_ID=12345
